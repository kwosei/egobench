# EgoBench environment variables
#
# Copy this file to `.env` and fill in the values for the providers you actually
# use. The CLI auto-loads `.env` on startup. Real shell env vars take precedence
# over values defined here.
#
# `.env` is gitignored; `.env.example` is committed.

# ---------------------------------------------------------------------------
# Provider API keys
# ---------------------------------------------------------------------------
# Every model reference in egobench.toml is `{ provider, model }`. The provider
# block declares which env var holds the API key (`api_key_env`). Local servers
# like LM Studio and Ollama declare no `api_key_env` and need no key at all.
#
# If a provider declares `api_key_env` but the env var is missing, EgoBench
# falls back to a deterministic recorded client — handy for offline tests.

# Required if you benchmark or judge any model through the `anthropic` provider.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Required if you benchmark, judge, or embed any model through the `openai` provider.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_ME

# Required only if you declare an `openrouter` provider in egobench.toml.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-REPLACE_ME
